# Backend runtime settings.
#
# Copy this file to .env for local development.
# Boolean values accept true/false.

# SQLite database URL used by FastAPI/SQLModel.
CD_DATABASE_URL=sqlite:///./classroom_downloader.db
# Coolify/Docker production example:
# CD_DATABASE_URL=sqlite:////data/classroom_downloader.db

# Frontend origin allowed by CORS and used after Google OAuth callback.
CD_FRONTEND_ORIGIN=http://localhost:5173
# Coolify production domain:
# CD_FRONTEND_ORIGIN=https://classroom.supernovasw.cloud

# Optional built frontend directory. Set in Docker to serve the Vite build from FastAPI.
# CD_STATIC_DIR=/app/static

# Google provider mode.
# Values:
# - mock: use local fake Classroom/Drive data; no Google credentials required.
# - google: use real Google OAuth + Classroom/Drive APIs.
CD_GOOGLE_PROVIDER=mock

# Required only when CD_GOOGLE_PROVIDER=google.
CD_GOOGLE_CLIENT_ID=
CD_GOOGLE_CLIENT_SECRET=
CD_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Coolify production callback:
# CD_GOOGLE_REDIRECT_URI=https://classroom.supernovasw.cloud/api/auth/google/callback

# Local OAuth token/state files.
CD_GOOGLE_TOKEN_PATH=.tokens/google-user.json
CD_GOOGLE_OAUTH_STATE_PATH=.tokens/google-oauth-state.txt
# Coolify/Docker persistent paths:
# CD_GOOGLE_TOKEN_PATH=/data/tokens/google-user.json
# CD_GOOGLE_OAUTH_STATE_PATH=/data/tokens/google-oauth-state.txt

# Server-side 24h grading file cache.
CD_GRADING_CACHE_PATH=.cache/grading
CD_GRADING_CACHE_TTL_HOURS=24
# Coolify/Docker persistent path:
# CD_GRADING_CACHE_PATH=/data/cache/grading

# Server-side export file cache.
# CD_EXPORT_CACHE_PATH=/data/cache/exports

# Grading engine.
# Values:
# - mock: deterministic local fake grader.
# - litellm: real LLM calls through LiteLLM.
CD_GRADING_ENGINE=mock

# LiteLLM selected model. Must match a model id in the merged catalog.
CD_LITELLM_MODEL=openai/gpt-5
CD_LITELLM_TIMEOUT_SECONDS=60
CD_LITELLM_MAX_RETRIES=2

# LLM provider API key(s). Required only when CD_GRADING_ENGINE=litellm.
#
# These are read directly by LiteLLM from the process environment using each
# provider's NATIVE variable name -- NOT the CD_ prefix. settings.py calls
# load_dotenv() at startup, so a key set here is exported to os.environ where
# LiteLLM looks. A real shell/system env var of the same name takes precedence.
#
# Set the one that matches CD_LITELLM_MODEL's provider, then uncomment it:
#   openai/*     -> OPENAI_API_KEY
#   anthropic/*  -> ANTHROPIC_API_KEY
#   gemini/*     -> GEMINI_API_KEY
# (See LiteLLM provider docs for others: azure, bedrock, vertex_ai, groq, ...)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Model catalog mode.
# Values:
# - remote_cached: fetch LiteLLM upstream when cache is stale, use cache if fetch fails.
# - local_only: never fetch, use cached/upstream file plus local overlay.
# - remote_required: fetch upstream or fail catalog loading.
CD_LLM_MODEL_CATALOG_MODE=remote_cached
CD_LLM_MODEL_CATALOG_URL=https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json
CD_LLM_MODEL_CATALOG_CACHE_PATH=.cache/llm/model-prices.json
CD_LLM_MODEL_OVERLAY_PATH=config/llm-model-overrides.json
CD_LLM_MODEL_CATALOG_MAX_AGE_HOURS=24
# Coolify/Docker persistent path:
# CD_LLM_MODEL_CATALOG_CACHE_PATH=/data/cache/llm/model-prices.json

# Console logging.
# CD_LOG_LEVEL values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
CD_LOG_LEVEL=INFO

# Render logs through Rich for readable local console output.
CD_LOG_RICH=true
# Recommended in Docker/Coolify logs:
# CD_LOG_RICH=false
# CD_LOG_FORMAT=json

# Include text previews in logs for extraction, privacy scrub, and grading payloads.
# This is intended for local operator visibility before wiring real LLM calls.
CD_LOG_PAYLOAD_PREVIEWS=true

# Maximum preview characters for textual payloads. Byte previews are capped lower.
CD_LOG_PREVIEW_CHARS=1000

# Sentry backend error reporting.
# Leave CD_SENTRY_DSN empty to keep Sentry fully disabled.
# In production, create a Sentry Python/FastAPI project, copy the DSN into the
# VPS/Coolify .env, and add an Issues alert that emails the project owner for
# new or regressed errors.
CD_SENTRY_DSN=
CD_SENTRY_ENVIRONMENT=dev
# Coolify production example:
# CD_SENTRY_ENVIRONMENT=production

# Admin observability access.
# Comma-separated Google account emails that may read /api/admin/* and see the
# Admin rail item. Leave empty to disable admin access.
CD_ADMIN_EMAILS=
# Production example:
# CD_ADMIN_EMAILS=teacher@example.edu,ops@example.edu

# Retention for structured AppEvent rows.
CD_APP_EVENT_RETENTION_DAYS=30

# Persist scrubbed LLM prompt/response payloads for admin troubleshooting.
# Disable if the deployment policy forbids storing AI payload text.
CD_LLM_PAYLOAD_LOGGING=true
CD_LLM_PAYLOAD_RETENTION_DAYS=14
